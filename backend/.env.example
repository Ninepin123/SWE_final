# 後端環境設定範本
# 使用方式：複製本檔為 .env（同目錄），填入自己本機的設定。
# .env 已列入 .gitignore，「不會」被提交，請勿把真實密碼寫進本檔。

# 預設連到 start.bat 自動下載/啟動的「可攜版 MySQL」（port 3307，免安裝）。
# 若你想用自己安裝的 MySQL，把這行改成你的 host:port 與帳密即可，
# start.bat 偵測到該位址有回應時會直接沿用、不會啟動可攜版。
DATABASE_URL=mysql+pymysql://nuksams_dev:nuksams_dev_password@127.0.0.1:3307/nuksams?charset=utf8mb4

# JWT 簽章金鑰（本機隨便填，正式環境由部署者產生）
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 允許的前端來源（Vite dev server）
CORS_ORIGINS=["http://localhost:5173"]
