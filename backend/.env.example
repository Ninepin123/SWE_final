# 後端環境設定範本
# 使用方式：複製本檔為 .env（同目錄），填入自己本機的設定。
# .env 已列入 .gitignore，「不會」被提交，請勿把真實密碼寫進本檔。

# 預設連到 start.bat 自動下載/啟動的「可攜版 MySQL」（port 3307，免安裝）。
# 若你想用自己安裝的 MySQL，把這行改成你的 host:port 與帳密即可，
# start.bat 偵測到該位址有回應時會直接沿用、不會啟動可攜版。
DATABASE_URL=mysql+pymysql://nuksams_dev:nuksams_dev_password@127.0.0.1:3307/nuksams?charset=utf8mb4

# JWT 簽章金鑰（本機隨便填，正式環境由部署者產生）
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 系統 bootstrap 管理員：只在資料庫沒有任何 ADMIN 帳號時建立。
# 這不是 demo/mock 資料；請首次登入後立即修改密碼，或在啟動前改成你要的值。
BOOTSTRAP_ADMIN_ACCOUNT=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!12345
BOOTSTRAP_ADMIN_NAME=系統管理員
BOOTSTRAP_ADMIN_EMAIL=

# 允許的前端來源（Vite dev server）
CORS_ORIGINS=["http://localhost:5173"]

# Email 通知（預設關閉，發通知時只會寫 email_logs 不會真的寄）。
# 要真的寄 Gmail：把 EMAIL_ENABLED 設成 true，並填入你的 Gmail 與「應用程式密碼」。
#   1. 先到 Google 帳號開啟兩步驟驗證
#   2. 產生 16 碼應用程式密碼（不是你平常登入的密碼）
#   3. SMTP_USER 填你的 Gmail，SMTP_PASSWORD 填那 16 碼
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
